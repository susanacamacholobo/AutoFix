--AQUI SE MUESTRA EL CONTENIDO DEL ARCHIVO .env.example, 
--QUE ES UN EJEMPLO DE CONFIGURACIÓN PARA LA BASE DE DATOS POSTGRESQL. 
--ESTE ARCHIVO NO DEBE SER COMMITADO AL REPOSITORIO, 
--YA QUE CONTIENE INFORMACIÓN SENSIBLE COMO CONTRASEÑAS. 
--EN SU LUGAR, LOS USUARIOS DEBEN CREAR SU PROPIO ARCHIVO .env 
--BASADO EN ESTE EJEMPLO Y RELLENAR LOS CAMPOS CON SUS PROPIAS 
--CREDENCIALES.

DATABASE_URL=postgresql://postgres:tu_contrasena@localhost:5432/autofix